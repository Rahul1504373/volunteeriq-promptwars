"""
agents.py — VolunteerIQ AI Agent Classes
PromptWars Challenge 4: Smart Stadiums & Tournament Ops

4 Gemini 1.5 Flash agents powering VolunteerIQ:
1. TranslatorAssistantAgent  — bilingual fan/volunteer response
2. CrowdReasoningAgent       — crowd safety decisions with full reasoning
3. AccessibilityRouterAgent  — step-free routing for fans with special needs
4. SituationBriefingAgent    — real-time shift briefings for volunteers

All agents:
- Use Gemini 1.5 Flash with max_output_tokens=800
- Return typed dicts with safe fallback on parse error
- Timeout: 30 seconds per Gemini call
- Docstrings on every method
"""

import json
import logging
import re
from typing import Any

from groq import Groq
import os

from data import STADIUM_DATA

logger = logging.getLogger("volunteeriq.agents")


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Utility helpers
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

def _extract_json(text: str) -> dict:
    """
    Extract and parse the first JSON object found in a text string.
    Strips markdown code fences if present.

    Args:
        text: Raw text potentially containing a JSON object.

    Returns:
        Parsed dict on success, empty dict on failure.
    """
    # Strip markdown code fences
    text = re.sub(r"```(?:json)?", "", text).strip()
    # Find first {...} block
    match = re.search(r"\{.*\}", text, re.DOTALL)
    if match:
        try:
            return json.loads(match.group())
        except json.JSONDecodeError as exc:
            logger.warning("JSON decode failed: %s", exc)
    return {}


def _get_groq_client():
    return Groq(api_key=os.getenv("GROQ_API_KEY", ""))


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CLASS 1 — TranslatorAssistantAgent
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

class TranslatorAssistantAgent:
    """
    The core volunteer superpower.

    A fan speaks ANY language → the volunteer gets the answer in BOTH
    the fan's language AND English simultaneously.
    This is the hero feature of VolunteerIQ: zero language barrier,
    zero seconds of awkward confusion, zero safety risk from
    miscommunication.

    Powered by Gemini 1.5 Flash with automatic language detection.
    """

    SYSTEM_PROMPT: str = """You are VolunteerIQ, an AI assistant
for FIFA World Cup 2026 stadium volunteers at MetLife Stadium.
A fan has approached a volunteer and asked a question.
The volunteer may not speak the fan's language.

Your job:
1. Detect the language of the fan's question automatically
2. Find the answer from the stadium knowledge provided
3. Give the volunteer TWO outputs simultaneously:
   a) The answer in the FAN'S LANGUAGE (for the fan to read/hear)
   b) The answer in English (for the volunteer to understand)
4. Add a 3-word action hint for the volunteer in [BRACKETS]

Rules:
- Never ask what language — detect automatically
- Be specific: gate names, section numbers, walking times
- For navigation: ALWAYS include reasoning
  ("Gate C is 96% full — go to Gate B instead, 3 min wait")
- For accessibility: always mention step-free alternatives
- For emergencies: fan language first, then call extension
- Keep fan-facing answer under 3 sentences
- Keep volunteer hint under 5 words in [BRACKETS]
- Tone: calm, helpful, confident

Output valid JSON only:
{
  "language_detected": "<full language name e.g. Portuguese>",
  "language_code": "<ISO 639-1 code e.g. pt>",
  "fan_response": "<answer in fan's language>",
  "volunteer_summary": "<answer in English for volunteer>",
  "volunteer_action_hint": "<3-5 words in [BRACKETS]>",
  "is_emergency": <true|false>,
  "requires_supervisor": <true|false>,
  "relevant_gate": "<gate name or null>",
  "accessibility_flag": <true|false>
}"""

    def __init__(self, model: genai.GenerativeModel) -> None:
        """
        Initialize the agent with a pre-configured Gemini model.

        Args:
            model: A genai.GenerativeModel instance ready for inference.
        """
        self._model = model

    def assist(
        self,
        fan_query: str,
        gate_context: dict,
        match_id: str,
    ) -> dict:
        """
        Process a fan's question and return a bilingual response.

        Detects the fan's language automatically, answers using live
        stadium data, and returns parallel text for both the fan and
        the volunteer. On any parse error returns a safe fallback
        that keeps the interaction moving.

        Args:
            fan_query:    The raw text of whatever the fan said,
                          in any language.
            gate_context: The current volunteer's gate dict from
                          STADIUM_DATA['gates'].
            match_id:     Match identifier (e.g. 'WC01') used to
                          determine which languages are expected.

        Returns:
            dict with keys: language_detected, language_code,
            fan_response, volunteer_summary, volunteer_action_hint,
            is_emergency, requires_supervisor, relevant_gate,
            accessibility_flag.
        """
        # Locate match for language context
        match_data = next(
            (m for m in STADIUM_DATA["matches"] if m["match_id"] == match_id),
            STADIUM_DATA["matches"][0],
        )

        # Build context-rich prompt
        prompt = f"""{self.SYSTEM_PROMPT}

=== STADIUM KNOWLEDGE ===
Venue: {STADIUM_DATA['venue']['name']}, {STADIUM_DATA['venue']['city']}
Today's match: {match_data['teams']} — kickoff {match_data['kickoff']}
Primary fan languages today: {', '.join(match_data['primary_languages'])}

=== VOLUNTEER'S CURRENT GATE ===
{json.dumps(gate_context, indent=2)}

=== ALL GATE STATUS (for redirect decisions) ===
{json.dumps(STADIUM_DATA['gates'], indent=2)}

=== FACILITIES ===
Food options: {json.dumps(STADIUM_DATA['facilities']['food'], indent=2)}
Restrooms: {json.dumps(STADIUM_DATA['facilities']['restrooms'], indent=2)}
Medical: {STADIUM_DATA['facilities']['medical']}
Prayer rooms: {STADIUM_DATA['facilities']['prayer_rooms']}
Family zone: {STADIUM_DATA['facilities']['family_zone']}
Lost & Found: {STADIUM_DATA['facilities']['lost_found']}

=== ACCESSIBILITY ===
{json.dumps(STADIUM_DATA['accessible_routes'], indent=2)}

=== TRANSPORT ===
Metro: {json.dumps(STADIUM_DATA['transport']['metro'], indent=2)}
Bus: {json.dumps(STADIUM_DATA['transport']['bus'], indent=2)}
Rideshare: {json.dumps(STADIUM_DATA['transport']['rideshare'], indent=2)}

=== EMERGENCY PROTOCOLS ===
{json.dumps(STADIUM_DATA['volunteer_quick_answers'], indent=2)}

=== FAN'S QUESTION ===
{fan_query}

Respond with valid JSON only. No markdown. No explanation outside JSON."""

        try:
            response = self._model.generate_content(
                prompt,
                generation_config=_generation_config(),
                request_options={"timeout": 30},
            )
            result = _extract_json(response.choices[0].message.content)
            if result:
                return result
        except Exception as exc:
            logger.error("TranslatorAssistantAgent.assist error: %s", exc)

        # Safe fallback — keeps volunteer moving
        return {
            "language_detected": "Unknown",
            "language_code": "en",
            "fan_response": "Please wait one moment — I am getting help for you. / Por favor espere — estoy buscando ayuda.",
            "volunteer_summary": "Unable to process query automatically. Please call supervisor ext 2000 for language assistance.",
            "volunteer_action_hint": "[Call supervisor now]",
            "is_emergency": False,
            "requires_supervisor": True,
            "relevant_gate": None,
            "accessibility_flag": False,
        }


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CLASS 2 — CrowdReasoningAgent
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

class CrowdReasoningAgent:
    """
    Goes beyond crowd detection — reasons over crowd data and generates
    actionable decisions with full, human-readable explanation.

    This is what separates VolunteerIQ from basic crowd counters.
    Any system can report '96% full'. Only VolunteerIQ explains WHY
    it matters, predicts time-to-critical, chooses the best redirect
    gate, and drafts multilingual crowd alerts — all in one call.

    Powered by Gemini 1.5 Flash reasoning over live gate density data.
    """

    SYSTEM_PROMPT: str = """You are a crowd safety AI for FIFA
World Cup 2026 at MetLife Stadium. You analyze live gate density data
and reason over it to make specific, actionable decisions.

Critical principle: Don't just detect — REASON and DECIDE.

Example reasoning quality expected:
"Gate C is at 96% capacity. At current inflow rate of ~200 fans/min,
it will reach 100% in approximately 2 minutes — creating a dangerous
crush risk. Gate D is at 20% with 3,200 remaining capacity and the
shortest wait time. DECISION: Redirect ALL incoming fans from Gate C
to Gate D immediately. Notify in Portuguese and Spanish since
Brazil vs Argentina fans are primary today."

Output valid JSON only:
{
  "overall_risk": "<Low|Medium|High|Critical>",
  "reasoning": "<detailed multi-sentence explanation of WHY>",
  "decision": "<specific action to take RIGHT NOW>",
  "redirect_from": "<gate name or null>",
  "redirect_to": "<gate name or null>",
  "time_to_critical_minutes": <number or null>,
  "alert_message": {
    "en": "<crowd alert in English>",
    "es": "<crowd alert in Spanish>",
    "pt": "<crowd alert in Portuguese>"
  },
  "volunteer_instruction": "<what the on-ground volunteer should do>",
  "estimated_wait_if_redirected_minutes": <number>
}"""

    def __init__(self, model: genai.GenerativeModel) -> None:
        """
        Initialize the agent with a pre-configured Gemini model.

        Args:
            model: A genai.GenerativeModel instance ready for inference.
        """
        self._model = model

    def analyze_and_decide(self, gates: list, match: dict) -> dict:
        """
        Analyze all gate densities and produce a fully reasoned
        redirect decision.

        Takes live gate occupancy data, calculates density percentages,
        and asks Gemini to reason over crowd flow, predict time-to-critical,
        and generate multilingual alert messages.

        Args:
            gates: List of gate dicts with current_occupancy and capacity.
                   Density percentages are recalculated here from live data.
            match: Current match dict including primary_languages.

        Returns:
            dict with keys: overall_risk, reasoning, decision,
            redirect_from, redirect_to, time_to_critical_minutes,
            alert_message (en/es/pt), volunteer_instruction,
            estimated_wait_if_redirected_minutes.
        """
        # Recalculate density_percent from live occupancy figures
        enriched_gates = []
        for gate in gates:
            g = dict(gate)
            if g.get("capacity", 0) > 0:
                g["density_percent"] = round(
                    (g["current_occupancy"] / g["capacity"]) * 100, 1
                )
            enriched_gates.append(g)

        prompt = f"""{self.SYSTEM_PROMPT}

=== LIVE GATE DATA ===
{json.dumps(enriched_gates, indent=2)}

=== TODAY'S MATCH ===
{json.dumps(match, indent=2)}

=== CONTEXT ===
Stadium capacity: {STADIUM_DATA['venue']['capacity']}
Accessible gates (wheelchair): Gate A, Gate B, Gate D
Gate C: NO wheelchair access, stairs only

Analyze the data, reason through it step by step, and output
the JSON decision. No markdown. No text outside the JSON object."""

        try:
            response = self._model.generate_content(
                prompt,
                generation_config=_generation_config(),
                request_options={"timeout": 30},
            )
            result = _extract_json(response.choices[0].message.content)
            if result:
                return result
        except Exception as exc:
            logger.error("CrowdReasoningAgent.analyze_and_decide error: %s", exc)

        # Safe fallback
        return {
            "overall_risk": "Unknown",
            "reasoning": "Unable to complete crowd analysis at this time. Monitor gates manually.",
            "decision": "Continue monitoring all gates. Contact supervisor ext 2000 if any gate exceeds 90%.",
            "redirect_from": None,
            "redirect_to": None,
            "time_to_critical_minutes": None,
            "alert_message": {
                "en": "Please use all available gates for entry.",
                "es": "Por favor use todas las puertas disponibles para entrar.",
                "pt": "Por favor use todos os portões disponíveis para entrar.",
            },
            "volunteer_instruction": "Manually check each gate status and report to supervisor.",
            "estimated_wait_if_redirected_minutes": 5,
        }


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CLASS 3 — AccessibilityRouterAgent
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

class AccessibilityRouterAgent:
    """
    Specialized agent for fans with accessibility needs.

    Handles wheelchair routing (step-free only), deaf/hard-of-hearing
    assistance, visual impairment support, family and stroller routes,
    and medical escort needs — in the fan's own language.

    Critically: detects the fan's language automatically and provides
    step-by-step instructions in BOTH the fan's language and English,
    so the volunteer can follow along and assist confidently.

    Powered by Gemini 1.5 Flash with full STADIUM_DATA accessibility
    knowledge injected into context.
    """

    SYSTEM_PROMPT: str = """You are an accessibility specialist AI
for FIFA World Cup 2026 at MetLife Stadium. A volunteer needs to help
a fan with accessibility needs. The fan may not speak English.

Your job:
1. Detect the fan's language automatically from their query
2. Identify the specific accessibility need
3. Provide step-by-step route instructions in the FAN'S language
4. Provide the same instructions in English for the volunteer
5. Always prefer step-free routes (NO stairs, NO escalators for wheelchair users)
6. CRITICAL: Gate C has NO elevator and NO wheelchair access — NEVER route
   wheelchair users to Gate C

Accessibility types you handle:
- Wheelchair/mobility — step-free routes only, elevators required
- Deaf/Hard of Hearing — caption screens, vibrating wristbands, interpreters
- Visual impairment — audio description service, tactile maps, guide dog areas
- Family — stroller routes, nursing rooms, family zones (Sections 140-145)
- Medical — nearest medical station, escort if needed
- Nursing — nursing room in family zone Section 140-145

Output valid JSON only:
{
  "language_detected": "<full language name>",
  "accessibility_type": "<Wheelchair|Deaf/HoH|Visual Impairment|Family|Medical|Nursing>",
  "fan_instructions": "<step-by-step in fan's language, numbered>",
  "volunteer_escort_needed": <true|false>,
  "route_description": "<English route description for volunteer>",
  "nearest_facility": "<specific location name and section>",
  "walking_time_minutes": <number>,
  "elevator_required": <true|false>,
  "elevator_location": "<elevator location string or null>",
  "additional_support": "<extra help available or null>",
  "emergency_flag": <true|false>
}"""

    def __init__(self, model: genai.GenerativeModel) -> None:
        """
        Initialize the agent with a pre-configured Gemini model.

        Args:
            model: A genai.GenerativeModel instance ready for inference.
        """
        self._model = model

    def route(self, fan_query: str, current_location: str) -> dict:
        """
        Generate an accessible route for a fan with special needs.

        Detects the fan's language and accessibility need from their
        query, then generates step-by-step instructions in both the
        fan's language and English, with elevator locations, walking
        times, and escort recommendations.

        Args:
            fan_query:        Raw text from the fan in any language.
            current_location: Volunteer's current gate/section
                              (e.g. 'Gate C', 'Section 140').

        Returns:
            dict with keys: language_detected, accessibility_type,
            fan_instructions, volunteer_escort_needed,
            route_description, nearest_facility, walking_time_minutes,
            elevator_required, elevator_location,
            additional_support, emergency_flag.
        """
        prompt = f"""{self.SYSTEM_PROMPT}

=== FULL ACCESSIBILITY DATA ===
{json.dumps(STADIUM_DATA['accessible_routes'], indent=2)}

=== ALL GATES (accessible status) ===
{json.dumps([
    {k: v for k, v in g.items()
     if k in ('id', 'name', 'accessible', 'elevator', 'density_percent', 'status', 'wait_minutes')}
    for g in STADIUM_DATA['gates']
], indent=2)}

=== FACILITIES ===
Medical stations: {STADIUM_DATA['facilities']['medical']}
Family zone: {STADIUM_DATA['facilities']['family_zone']}
Prayer rooms: {STADIUM_DATA['facilities']['prayer_rooms']}
Restrooms (accessible): {json.dumps([r for r in STADIUM_DATA['facilities']['restrooms'] if r['accessible']], indent=2)}

=== VOLUNTEER'S CURRENT LOCATION ===
{current_location}

=== FAN'S QUERY ===
{fan_query}

Output valid JSON only. No markdown. No text outside the JSON object."""

        try:
            response = self._model.generate_content(
                prompt,
                generation_config=_generation_config(),
                request_options={"timeout": 30},
            )
            result = _extract_json(response.choices[0].message.content)
            if result:
                return result
        except Exception as exc:
            logger.error("AccessibilityRouterAgent.route error: %s", exc)

        # Safe fallback — always routes to Accessibility Services Desk
        return {
            "language_detected": "Unknown",
            "accessibility_type": "General Assistance",
            "fan_instructions": "Please follow the volunteer to the Accessibility Services Desk for full assistance.",
            "volunteer_escort_needed": True,
            "route_description": "Escort fan to Accessibility Services Desk. It is located near Gate B, clearly signposted throughout the stadium.",
            "nearest_facility": "Accessibility Services Desk — near Gate B",
            "walking_time_minutes": 5,
            "elevator_required": False,
            "elevator_location": None,
            "additional_support": "Accessibility Services Desk staff available all match hours.",
            "emergency_flag": False,
        }


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CLASS 4 — SituationBriefingAgent
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

class SituationBriefingAgent:
    """
    Gives volunteers a real-time AI-generated briefing every 15 minutes.

    Tells each volunteer exactly what is happening at their specific gate,
    what to expect in the next 30 minutes, which languages they will
    encounter based on today's match, the top 3 questions they will
    get (so they can answer without hesitation), and when to escalate.

    This transforms a volunteer from reactive to proactive — knowing
    what is coming before it arrives.

    Powered by Gemini 1.5 Flash with gate + match + crowd context.
    """

    SYSTEM_PROMPT: str = """You are a shift briefing AI for
FIFA World Cup 2026 stadium volunteers at MetLife Stadium.
Generate a 60-second briefing a volunteer can read quickly
before their shift or refresh every 15 minutes.

Be specific, practical, and actionable. Use the exact gate data provided.
Address the volunteer directly (use 'You' / 'Your gate').

Format your response EXACTLY using these section headers
(include the colon, keep each section concise):

GATE STATUS: <one clear sentence about their gate right now>

CROWD FORECAST: <next 30 minutes prediction based on current density and match time>

LANGUAGES TODAY: <which languages to expect, why, and key phrases in those languages>

TOP 3 QUESTIONS YOU WILL GET:
1. <most common question for this match/gate>
2. <second most common>
3. <third most common>

WATCH OUT FOR: <1-2 specific risks or situations this shift>

ESCALATE IF: <clear conditions requiring supervisor — be specific, no vague advice>"""

    def __init__(self, model: genai.GenerativeModel) -> None:
        """
        Initialize the agent with a pre-configured Gemini model.

        Args:
            model: A genai.GenerativeModel instance ready for inference.
        """
        self._model = model

    def brief(
        self,
        volunteer_gate: str,
        match: dict,
        gates: list,
    ) -> dict:
        """
        Generate a structured real-time shift briefing for a volunteer.

        Produces a text briefing from Gemini then parses it into
        a structured dict by splitting on the known section headers,
        making each section independently renderable in the frontend.

        Args:
            volunteer_gate: Gate ID the volunteer is stationed at
                            (e.g. 'gate_c').
            match:          Today's match dict from STADIUM_DATA['matches'].
            gates:          All gate status data for crowd context.

        Returns:
            dict with keys: gate_status, crowd_forecast, languages_today,
            top_3_questions, watch_out_for, escalate_if, raw_text.
            Each value is a string with the section content.
        """
        # Find this volunteer's gate data
        gate_data = next(
            (g for g in gates if g["id"] == volunteer_gate),
            gates[0],
        )

        prompt = f"""{self.SYSTEM_PROMPT}

=== YOUR GATE ===
{json.dumps(gate_data, indent=2)}

=== TODAY'S MATCH ===
{json.dumps(match, indent=2)}

=== ALL GATES STATUS ===
{json.dumps(gates, indent=2)}

=== STADIUM CONTEXT ===
Volunteer stations: {STADIUM_DATA['venue']['volunteer_stations']}
Emergency numbers: Medical ext 2112, Security ext 911, Supervisor ext 2000
Accessibility desk: near Gate B
Family zone: Sections 140-145

Generate the briefing now. Use the exact header format specified."""

        raw_text = ""
        try:
            response = self._model.generate_content(
                prompt,
                generation_config=_generation_config(),
                request_options={"timeout": 30},
            )
            raw_text = response.choices[0].message.content.strip()
        except Exception as exc:
            logger.error("SituationBriefingAgent.brief error: %s", exc)
            raw_text = (
                f"GATE STATUS: {gate_data['name']} is at {gate_data['density_percent']}% capacity.\n"
                f"CROWD FORECAST: Monitor current flow and redirect if density exceeds 90%.\n"
                f"LANGUAGES TODAY: Expect {', '.join(match['primary_languages'])} speakers for {match['teams']}.\n"
                "TOP 3 QUESTIONS YOU WILL GET:\n1. Where are the restrooms?\n2. Where is my seat?\n3. Where is food?\n"
                "WATCH OUT FOR: Gate congestion during peak entry.\n"
                "ESCALATE IF: Gate density exceeds 90% or any medical emergency."
            )

        # Parse sections from the formatted text
        sections = _parse_briefing_sections(raw_text)
        sections["raw_text"] = raw_text
        return sections


def _parse_briefing_sections(text: str) -> dict:
    """
    Parse a SituationBriefingAgent response into a structured dict.

    Splits the free-text briefing on known section headers and returns
    each section's content as a trimmed string. Missing sections get
    a placeholder value so the frontend never renders an empty card.

    Args:
        text: Raw text response from Gemini with section headers.

    Returns:
        dict with keys: gate_status, crowd_forecast, languages_today,
        top_3_questions, watch_out_for, escalate_if.
    """
    header_map: dict[str, str] = {
        "GATE STATUS:": "gate_status",
        "CROWD FORECAST:": "crowd_forecast",
        "LANGUAGES TODAY:": "languages_today",
        "TOP 3 QUESTIONS YOU WILL GET:": "top_3_questions",
        "WATCH OUT FOR:": "watch_out_for",
        "ESCALATE IF:": "escalate_if",
    }

    result: dict[str, str] = {v: "" for v in header_map.values()}
    current_key: str | None = None

    for line in text.splitlines():
        matched = False
        for header, key in header_map.items():
            if line.strip().upper().startswith(header.upper()):
                current_key = key
                # Content may start on same line after the header
                remainder = line.strip()[len(header):].strip()
                if remainder:
                    result[current_key] = remainder
                matched = True
                break
        if not matched and current_key:
            separator = "\n" if result[current_key] else ""
            result[current_key] += separator + line.rstrip()

    # Clean up each section
    for key in result:
        result[key] = result[key].strip()
        if not result[key]:
            result[key] = "Information not available — contact supervisor."

    return result
